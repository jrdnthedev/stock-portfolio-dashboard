{
  "name": "stock-portfolio-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Stock Portfolio Dashboard - Monorepo",
  "scripts": {
    "prepare": "husky",
    "start": "powershell -ExecutionPolicy Bypass -File ./start-dev.ps1",
    "start:backend": "powershell -ExecutionPolicy Bypass -File ./start-backend.ps1",
    "stop": "powershell -ExecutionPolicy Bypass -File ./stop-dev.ps1",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run lint --workspace=portfolio-dashboard",
    "lint:backend": "cd backend && ruff check .",
    "format": "npm run format:frontend && npm run format:backend",
    "format:frontend": "npm run format --workspace=portfolio-dashboard",
    "format:backend": "cd backend && black . && ruff check --fix .",
    "type-check": "npm run type-check:frontend && npm run type-check:backend",
    "type-check:frontend": "npm run type-check --workspace=portfolio-dashboard",
    "type-check:backend": "cd backend && mypy .",
    "test": "npm run test:frontend",
    "test:frontend": "npm run test --workspace=portfolio-dashboard",
    "test:backend": "cd backend && pytest"
  },
  "workspaces": [
    "portfolio-dashboard"
  ],
  "overrides": {
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.4",
    "@angular/compiler": "^20.3.0",
    "@angular/compiler-cli": "^20.3.0",
    "@commitlint/cli": "^19.0.3",
    "@commitlint/config-conventional": "^19.0.3",
    "husky": "^9.0.11"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
